{
  "id": "codebase-memory",
  "display_name": "Codebase Memory MCP",
  "priority": "P0",
  "status": "candidate-pilot",
  "capabilities": [
    "code-intelligence",
    "architecture-query",
    "code-graph"
  ],
  "default_enabled": false,
  "risk": "medium-high",
  "roles": {
    "allowed": [
      "system-analyst",
      "technical-leader",
      "developer-backend",
      "developer-frontend"
    ],
    "optional": [
      "qa-engineer",
      "devops-engineer",
      "data-scientist"
    ],
    "forbidden": [
      "general-coordinator",
      "business-analyst",
      "project-manager",
      "data-analyst",
      "ui-ux-designer",
      "content-creator"
    ]
  },
  "runtime": {
    "transport": "stdio",
    "implementation": "external-or-adapter-specific",
    "source_url": "https://github.com/DeusData/codebase-memory-mcp",
    "install_location": "/opt/eksad-mcp/bin/codebase-memory-mcp"
  },
  "env_contract": [
    {
      "name": "CBM_ALLOWED_ROOT",
      "required": true,
      "secret": false,
      "description": "Allowed repository root; use /workspace or narrower."
    },
    {
      "name": "CBM_WORKERS",
      "required": false,
      "secret": false,
      "description": "Worker count; use 1 on small VPS."
    },
    {
      "name": "CBM_CACHE_DIR",
      "required": false,
      "secret": false,
      "description": "Local cache directory outside Git."
    }
  ],
  "hermes_config": {
    "server_name": "codebase_memory",
    "command": "/opt/eksad-mcp/bin/codebase-memory-mcp",
    "args": [],
    "env": {
      "CBM_ALLOWED_ROOT": "/workspace",
      "CBM_WORKERS": "1",
      "CBM_LOG_LEVEL": "warn"
    },
    "timeout": 120,
    "connect_timeout": 60,
    "sampling": {
      "enabled": false
    }
  },
  "generic_harness": {
    "capability_contract": [
      "code-intelligence",
      "architecture-query",
      "code-graph"
    ],
    "requires_explicit_runtime_binding": true,
    "fallback_required": true
  },
  "notes": "Use controlled pilot only. No auto-watch/global indexing. Prefer persistence=false."
}
