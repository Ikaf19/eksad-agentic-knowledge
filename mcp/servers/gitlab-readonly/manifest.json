{
  "id": "gitlab-readonly",
  "display_name": "GitLab Read-only MCP",
  "priority": "P0",
  "status": "candidate",
  "capabilities": [
    "git-read-only",
    "merge-requests-read-only",
    "issues-read-only"
  ],
  "default_enabled": false,
  "risk": "medium",
  "roles": {
    "allowed": [
      "technical-leader",
      "developer-backend",
      "developer-frontend",
      "qa-engineer",
      "project-manager",
      "devops-engineer"
    ],
    "optional": [
      "general-coordinator",
      "business-analyst",
      "system-analyst",
      "data-analyst",
      "data-scientist",
      "ui-ux-designer",
      "content-creator"
    ],
    "forbidden": []
