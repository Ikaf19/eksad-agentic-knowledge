{
  "id": "sonarqube-readonly",
  "display_name": "SonarQube Read-only MCP",
  "priority": "P1",
  "status": "planned",
  "capabilities": [
    "quality-evidence",
    "static-analysis-read-only"
  ],
  "default_enabled": false,
  "risk": "medium",
  "roles": {
    "allowed": [
      "technical-leader",
      "devops-engineer",
      "project-manager"
    ],
    "optional": [
      "developer-backend",
      "developer-frontend",
      "qa-engineer"
    ],
    "forbidden": [
      "business-analyst",
      "general-coordinator"
    ]
  },
  "runtime": {
    "transport": "stdio",
