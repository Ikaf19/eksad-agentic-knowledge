    "command": "/opt/eksad-mcp/bin/sonarqube-readonly",
    "args": [],
    "env": {
      "SONARQUBE_BASE_URL": "${SONARQUBE_BASE_URL}",
      "SONARQUBE_READONLY_TOKEN": "${SONARQUBE_READONLY_TOKEN}"
    },
    "timeout": 120,
    "connect_timeout": 60,
    "sampling": {
      "enabled": false
    }
  },
  "generic_harness": {
    "capability_contract": [
      "quality-evidence",
      "static-analysis-read-only"
