  "roles": {
    "allowed": [
      "technical-leader",
      "devops-engineer"
    ],
    "optional": [
      "qa-engineer",
      "project-manager",
      "data-analyst",
      "data-scientist"
    ],
    "forbidden": [
      "general-coordinator",
      "business-analyst",
      "system-analyst",
      "developer-backend",
      "developer-frontend",
      "ui-ux-designer",
