{
  "id": "content-draft",
  "display_name": "Content Draft MCP",
  "priority": "P2",
  "status": "optional",
  "capabilities": [
    "content-repository-draft"
  ],
  "default_enabled": false,
  "risk": "medium",
  "roles": {
    "allowed": [
      "content-creator"
    ],
    "optional": [
      "project-manager",
      "ui-ux-designer"
    ],
    "forbidden": [
      "general-coordinator",
      "business-analyst",
      "system-analyst",
      "technical-leader",
      "developer-backend",
      "developer-frontend",
      "qa-engineer",
      "devops-engineer",
      "data-analyst",
      "data-scientist"
    ]
  },
  "runtime": {
    "transport": "stdio",
    "implementation": "external-or-adapter-specific",
    "source_url": "TBD approved docs/CMS draft connector implementation",
    "install_location": "/opt/eksad-mcp/bin/content-draft"
  },
  "env_contract": [
    {
      "name": "CONTENT_DRAFT_ROOT",
      "required": true,
      "secret": false,
      "description": "Approved draft-only repository/root."
    },
    {
      "name": "CONTENT_DRAFT_TOKEN",
      "required": false,
      "secret": true,
      "description": "Optional draft-only docs/CMS token with no publish permission."
    }
  ],
  "hermes_config": {
    "server_name": "content_draft",
    "command": "/opt/eksad-mcp/bin/content-draft",
    "args": [],
    "env": {
      "CONTENT_DRAFT_ROOT": "${CONTENT_DRAFT_ROOT}",
      "CONTENT_DRAFT_TOKEN": "${CONTENT_DRAFT_TOKEN}"
    },
    "timeout": 120,
    "connect_timeout": 60,
    "sampling": {
      "enabled": false
    }
  },
  "generic_harness": {
    "capability_contract": [
      "content-repository-draft"
    ],
    "requires_explicit_runtime_binding": true,
    "fallback_required": true
  },
  "notes": "Draft-only content repository access. Publishing or external posting always requires explicit approval."
}
