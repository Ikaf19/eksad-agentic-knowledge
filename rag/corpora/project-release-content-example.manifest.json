{
  "id": "project-release-content-example",
  "version": "1.0.0",
  "description": "Project-specific release/content evidence corpus template for approved release notes, user-guide sources, training drafts, and publication evidence. Not indexed by default.",
  "status": "example",
  "source_layer": "project-specific",
  "indexable": false,
  "sensitivity": "project-confidential",
  "paths": [
    "projects/<project-code>/release/**/*.md",
    "projects/<project-code>/content/**/*.md",
    "projects/<project-code>/training/**/*.md"
  ],
  "exclude": [
    "**/.env",
    "**/.env.*",
    "**/secrets/**",
    "**/raw-dumps/**"
  ],
  "default_chunk_profile": "project-content-evidence",
  "allowed_roles": [
    "business-analyst",
    "technical-leader",
    "qa-engineer",
    "project-manager",
    "devops-engineer",
    "ui-ux-designer",
    "content-creator"
  ],
  "citation_required": true,
  "freshness": {
    "strategy": "project-controlled",
    "tracked_paths": [
      "projects/<project-code>/**"
    ]
  },
  "activation": {
    "default": "disabled",
    "requires": [
      "project approval",
      "publication owner approval",
      "sensitivity review",
      "approved source artifacts only"
    ]
  }
}
