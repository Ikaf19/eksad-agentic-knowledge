{
  "id": "project-specific-example",
  "version": "1.0.0",
  "description": "Template for future project/customer-specific RAG corpus activation. Not indexed by default.",
  "status": "example",
  "source_layer": "project-specific",
  "indexable": false,
  "sensitivity": "project-confidential",
  "paths": [
    "projects/<project-code>/**/*.md"
  ],
  "exclude": [
    "**/.env",
    "**/.env.*",
    "**/secrets/**",
    "**/raw-dumps/**"
  ],
  "default_chunk_profile": "project-deliverable",
  "allowed_roles": [
    "business-analyst",
    "system-analyst",
    "technical-leader",
    "qa-engineer",
    "project-manager"
  ],
  "citation_required": true,
  "freshness": {
    "strategy": "project-controlled",
    "tracked_paths": [
      "projects/<project-code>/**"
    ]
  },
  "activation": {
    "default": "disabled",
    "requires": [
      "project approval",
      "scope definition",
      "sensitivity review"
    ]
  }
}
