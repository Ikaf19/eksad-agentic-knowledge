{
  "id": "project-specific-example",
  "version": "1.0.0",
  "description": "Umbrella template for future project/customer-specific RAG corpus activation. Prefer split templates for specs, data evidence, design assets, and release/content evidence. Not indexed by default.",
  "status": "example",
  "source_layer": "project-specific",
  "indexable": false,
  "sensitivity": "project-confidential",
  "paths": [
    "projects/<project-code>/**/*.md"
  ],
  "exclude": [
    "**/.env",
    "**/.env.*",
    "**/secrets/**",
    "**/raw-dumps/**"
  ],
  "default_chunk_profile": "project-deliverable",
  "allowed_roles": [
    "general-coordinator",
    "business-analyst",
    "system-analyst",
    "technical-leader",
    "developer-backend",
    "developer-frontend",
    "qa-engineer",
    "project-manager",
    "devops-engineer",
    "data-analyst",
    "data-scientist",
    "ui-ux-designer",
    "content-creator"
  ],
  "citation_required": true,
  "freshness": {
    "strategy": "project-controlled",
    "tracked_paths": [
      "projects/<project-code>/**"
    ]
  },
  "activation": {
    "default": "disabled",
    "requires": [
      "project approval",
      "scope definition",
      "sensitivity review",
      "role access matrix approval"
    ]
  }
}
